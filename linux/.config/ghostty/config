initial-command = "/bin/zsh -lc 'fastfetch; exec /bin/zsh -l'"
command = "/bin/zsh"

theme="Rose Pine"
cursor-color=#f6c177
cursor-text=#191724
font-family="Geist Mono"
font-feature=ss11
font-thicken=false
font-size=11

adjust-cell-height=5%

cursor-click-to-move=true
mouse-hide-while-typing=true

background-opacity=0.8
background-blur-radius=32

unfocused-split-opacity=0.5

window-padding-x=10
window-padding-y=10

window-inherit-working-directory=false

window-save-state=always

confirm-close-surface=false

auto-update=download

quick-terminal-position=top
quick-terminal-size=750px
keybind = global:shift+ctrl+q=toggle_quick_terminal

# Fix general slowness on hyprland (https://github.com/ghostty-org/ghostty/discussions/3224)
async-backend = epoll
