#!/usr/bin/env bash

set -euo pipefail

if [[ $# -ne 1 ]]; then
  printf 'Usage: %s <cartograph-zip-or-directory>\n' "${0##*/}" >&2
  exit 1
fi

source_path=$1
font_dir="$HOME/.local/share/fonts"
tmp_dir=

cleanup() {
  if [[ -n "${tmp_dir}" && -d "${tmp_dir}" ]]; then
    rm -rf "$tmp_dir"
  fi
}

trap cleanup EXIT

mkdir -p "$font_dir"

if [[ -d "$source_path" ]]; then
  cp "$source_path"/CartographCF-*.otf "$font_dir"/
elif [[ -f "$source_path" ]]; then
  tmp_dir=$(mktemp -d)
  unzip -q "$source_path" -d "$tmp_dir"
  cp "$tmp_dir"/CartographCF-*.otf "$font_dir"/
else
  printf 'Path not found: %s\n' "$source_path" >&2
  exit 1
fi

chmod 644 "$font_dir"/CartographCF-*.otf
fc-cache -fv >/dev/null

printf 'Installed Cartograph CF into %s\n' "$font_dir"
fc-match monospace
